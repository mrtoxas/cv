mixin career(data)
	.career
		ul.carrer-list.list-clear
			each item in data
				li.career-item
					.career-head
						h3.career-title(data-i18n=item.title[0])= item.title[1]
						.career-years= item.years
					.career-content
						div
							if item.subtitle
								.career-subttle(data-i18n=item.subtitle[0])= item.subtitle[1]
							.career-main
								each main in item.main
									div(data-i18n=main[0])= main[1]
							if item.extra		
								.carrer-extra(data-i18n=item.extra[0])= item.extra[1]
							if item.technologies
								.carrer-technologies
									ul.list-clear
										each tech in item.technologies
											li(data-i18n=tech)= tech

